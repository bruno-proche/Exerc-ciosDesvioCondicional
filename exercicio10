/******************************************************************************
Faça um algoritmo que solicite ao usuário uma data, composta de 3 variáveis: dia, mês e ano. Informe 
se a data digitada é válida ou não, considerando: 
• Anos bissextos (conforme regra descrita no exercício 11): em anos bissextos fevereiro possui 29 
dias. Nos outros anos 28 dias. 
• Meses: existem somente meses de 1 a 12. 
• Dias: os meses de 1, 3, 5, 7, 8, 10 e 12 possuem 31 dias. 
O mês de fevereiro pode possuir 28 ou 29 dias. O restante possui 30 dias. 
• Um ano nunca será negativo.

*******************************************************************************/
#include <iostream>
using namespace std;

int main()
{
    int dia, mes, ano, diasnomes;
    cout<<"Digite um dia: ";
    cin>>dia;
    cout<<"Digite um mês 1 a 12: ";
    cin>>mes;
    cout<<"Digite um ano: ";
    cin>>ano;
    
    if (ano < 0){
        cout<<"Um ano nunca será negativo!";
        return 1;
    }
    
    if (mes < 1 || mes > 12){
        cout<<"Mês inválido. Tente novamente!";
        return 1;
    }
    
    bool bissexto = (ano % 400 == 0) || (ano % 4 == 0 && ano % 100 != 0);
    
    if (mes == 2){
        if (!bissexto){
        diasnomes = 28;    
        }
        else {
        diasnomes = 29;
        }
    }
    else if (mes == 1 || mes == 3 || mes == 5 || mes == 7 || mes == 8 || mes == 10 || mes == 12){
        diasnomes = 31;
    }
    else {
        diasnomes = 30;
    }
    
    if (dia >= 1 && dia <= diasnomes){
        cout<<"Data válida!";
    }
    else {
        cout<<"Data inválida!";
    }
    return 0;
}
