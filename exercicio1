#include <iostream>
using namespace std;

/*Faça um programa que solicita ao usuário uma letra e verifique se ela é uma vogal ou não exibindo 
uma mensagem correspondente. Saídas: 
Pedido ao usuário= "Digite uma letra:"; 
• Caso verdadeiro = “É uma vogal”; 
• Caso falso = “Não é uma vogal”.*/

void vogal(char a){
    if (!isalpha(a)){
        cout<<"Você digitou um número ou símbolo! ";
        return;
    }
    a = tolower(a);
    if (a == 'a' || a == 'e' || a == 'i' || a == 'o' || a == 'u'){
        cout<< "A sua letra é uma vogal";
    }
    else{
        cout<<"A sua letra não é uma vogal";
    }
    
}
int main()
{   
    char a;
    cout<<"Digite uma letra:";
    cin>>a;
    vogal(a);

    return 0;
}

